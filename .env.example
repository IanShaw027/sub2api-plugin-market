# sub2api-plugin-market 环境变量示例
# 详细说明见 docs/ENV-VARIABLES.md

# === 数据库 ===
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plugin_market
DB_SSLMODE=disable

# === 服务 ===
PORT=8081
GIN_MODE=debug

# === 安全 (生产必填) ===
ADMIN_JWT_SECRET=change-me-in-production
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# === 插件签名 (可选) ===
# PLUGIN_SIGNING_KEY_ID=dev-key-1
# PLUGIN_SIGNING_PRIVATE_KEY=<hex-encoded-ed25519-64-bytes>

# === GitHub API (可选,推荐) ===
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
