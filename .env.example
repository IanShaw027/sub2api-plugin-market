# 服务器配置
PORT=8081

# 数据库配置
DB_HOST=localhost
# 5433 matches docker-compose host mapping; avoids conflict with local PostgreSQL on 5432
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plugin_market
DB_SSLMODE=disable

# Storage 配置
STORAGE_TYPE=minio
STORAGE_LOCAL_PATH=./data/artifacts
STORAGE_LOCAL_URL=http://localhost:8081/artifacts
STORAGE_MINIO_ENDPOINT=localhost:9000
STORAGE_MINIO_ACCESS_KEY=minioadmin
STORAGE_MINIO_SECRET_KEY=minioadmin
STORAGE_MINIO_BUCKET=plugin-market
STORAGE_MINIO_USE_SSL=false
STORAGE_MINIO_BASE_URL=http://localhost:9000

# 信任密钥配置
TRUST_KEYS_PATH=./data/trust_keys

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 管理后台配置（必填）
ADMIN_JWT_SECRET=YOUR_TOKEN_HERE

# CORS 白名单（可选，逗号分隔；不配置时默认仅允许 localhost/127.0.0.1）
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
